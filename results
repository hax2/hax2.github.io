<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>WCS Model Suite</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f6f7f9;
      --panel: #ffffff;
      --ink: #18212f;
      --muted: #5c6878;
      --line: #d9dee7;
      --accent: #2563eb;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: var(--bg);
      color: var(--ink);
    }
    header {
      padding: 24px 28px 16px;
      border-bottom: 1px solid var(--line);
      background: var(--panel);
    }
    h1 {
      margin: 0 0 6px;
      font-size: 24px;
      line-height: 1.2;
      letter-spacing: 0;
    }
    .subhead {
      margin: 0;
      color: var(--muted);
      font-size: 14px;
    }
    main {
      padding: 20px 28px 32px;
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr);
      gap: 20px;
    }
    aside, section {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 8px;
    }
    aside {
      padding: 16px;
      align-self: start;
      position: sticky;
      top: 16px;
      max-height: calc(100vh - 32px);
      overflow: auto;
    }
    .control-group {
      margin-bottom: 18px;
    }
    section {
      padding: 16px;
      min-width: 0;
    }
    .control-title {
      margin: 0 0 10px;
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 700;
    }
    .segmented {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 4px;
      padding: 4px;
      background: #eef1f5;
      border-radius: 8px;
      margin-bottom: 16px;
    }
    .bulk-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 6px;
      margin-bottom: 10px;
    }
    .bulk-actions button, .pair-row button {
      border: 1px solid var(--line);
      background: #fff;
      color: var(--ink);
      border-radius: 6px;
      padding: 7px 8px;
      font: inherit;
      font-size: 12px;
      cursor: pointer;
    }
    .bulk-actions button:hover, .pair-row button:hover {
      border-color: #aab4c2;
      background: #f8fafc;
    }
    .segmented button, .metric-select button {
      border: 0;
      background: transparent;
      border-radius: 6px;
      padding: 8px 6px;
      color: var(--muted);
      font: inherit;
      font-size: 13px;
      cursor: pointer;
    }
    .segmented button.active, .metric-select button.active {
      background: var(--panel);
      color: var(--ink);
      box-shadow: 0 1px 3px rgba(15, 23, 42, 0.12);
      font-weight: 650;
    }
    .metric-select {
      display: grid;
      grid-template-columns: 1fr;
      gap: 6px;
      margin-bottom: 18px;
    }
    .model-list {
      display: grid;
      gap: 10px;
    }
    .pair-row {
      border: 1px solid #e3e8ef;
      border-radius: 8px;
      padding: 8px;
      background: #fbfcfe;
    }
    .pair-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 8px;
      align-items: center;
      margin-bottom: 7px;
    }
    .pair-title {
      font-size: 12px;
      font-weight: 750;
      color: var(--ink);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .pair-actions {
      display: flex;
      gap: 4px;
    }
    .pair-actions button {
      padding: 4px 6px;
      font-size: 11px;
    }
    .pair-models {
      display: grid;
      gap: 6px;
    }
    label.model-toggle {
      display: grid;
      grid-template-columns: 16px minmax(0, 1fr) auto;
      gap: 8px;
      align-items: start;
      font-size: 13px;
      line-height: 1.25;
      cursor: pointer;
    }
    input[type="checkbox"] {
      width: 14px;
      height: 14px;
      margin: 1px 0 0;
      accent-color: var(--accent);
    }
    .swatch {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      margin-right: 6px;
      vertical-align: -1px;
    }
    .variant-pill {
      border: 1px solid #d8dee8;
      border-radius: 999px;
      padding: 2px 6px;
      font-size: 10px;
      line-height: 1.2;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      white-space: nowrap;
    }
    .variant-pill.instruct {
      border-color: #b8c7dc;
      color: #334155;
      background: #eef4ff;
    }
    .chart-head {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: start;
      margin-bottom: 8px;
    }
    h2 {
      margin: 0;
      font-size: 18px;
      line-height: 1.3;
      letter-spacing: 0;
    }
    .chart-meta {
      color: var(--muted);
      font-size: 13px;
      text-align: right;
    }
    .chart-wrap {
      position: relative;
      width: 100%;
      min-height: 560px;
    }
    svg {
      display: block;
      width: 100%;
      height: 560px;
      overflow: visible;
    }
    .axis text, .grid-label {
      fill: var(--muted);
      font-size: 11px;
    }
    .grid {
      stroke: #e6eaf0;
      stroke-width: 1;
    }
    .axis-line {
      stroke: #aab4c2;
      stroke-width: 1;
    }
    .series {
      fill: none;
      stroke-width: 2.4;
      stroke-linejoin: round;
      stroke-linecap: round;
    }
    .series.base {
      stroke-dasharray: none;
    }
    .series.instruct {
      stroke-dasharray: 7 5;
    }
    .point {
      stroke: #fff;
      stroke-width: 1.4;
      cursor: crosshair;
    }
    .default-line {
      stroke: #111827;
      stroke-width: 1.2;
      stroke-dasharray: 5 5;
      opacity: 0.55;
    }
    .default-point {
      stroke: #111827;
      stroke-width: 1.5;
      fill: #fff;
    }
    .default-label {
      fill: #111827;
      font-size: 11px;
      font-weight: 700;
    }
    .tooltip {
      position: absolute;
      min-width: 220px;
      padding: 10px 12px;
      border-radius: 8px;
      background: rgba(15, 23, 42, 0.94);
      color: #fff;
      font-size: 12px;
      line-height: 1.45;
      pointer-events: none;
      transform: translate(12px, -50%);
      display: none;
      z-index: 5;
      box-shadow: 0 12px 30px rgba(15, 23, 42, 0.24);
    }
    .tooltip strong {
      display: block;
      margin-bottom: 4px;
      font-size: 13px;
    }
    .notes {
      margin-top: 14px;
      display: grid;
      gap: 8px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
    }
    .default-list {
      margin-top: 18px;
      padding-top: 14px;
      border-top: 1px solid var(--line);
      display: grid;
      gap: 8px;
      font-size: 12px;
      color: var(--muted);
      line-height: 1.35;
    }
    .style-key {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 6px 8px;
      align-items: center;
      margin-bottom: 14px;
      color: var(--muted);
      font-size: 12px;
    }
    .sample-line {
      width: 34px;
      height: 0;
      border-top: 2.4px solid #334155;
    }
    .sample-line.dashed {
      border-top-style: dashed;
    }
    .default-list strong {
      color: var(--ink);
    }
    .loader {
      padding: 18px;
      color: var(--muted);
      border: 1px dashed var(--line);
      border-radius: 8px;
      margin-top: 12px;
    }
    .loader input {
      margin-top: 10px;
      max-width: 100%;
    }
    @media (max-width: 900px) {
      main {
        grid-template-columns: 1fr;
        padding: 16px;
      }
      aside {
        position: static;
        max-height: none;
      }
      .chart-wrap, svg {
        min-height: 520px;
        height: 520px;
      }
      .chart-head {
        display: block;
      }
      .chart-meta {
        text-align: left;
        margin-top: 4px;
      }
    }
  </style>
</head>
<body>
  <header>
    <h1>Word Coverage Score Model Suite</h1>
    <p class="subhead">Interactive views from <code>useforgraphs.csv</code>. Model colors are fixed across all decoder graphs.</p>
  </header>
  <main>
    <aside>
      <div class="control-group">
        <p class="control-title">Decoder</p>
        <div class="segmented" id="decoderTabs">
          <button type="button" data-decoder="top_p" class="active">top-p</button>
          <button type="button" data-decoder="top_k">top-k</button>
          <button type="button" data-decoder="min_p">min-p</button>
        </div>
      </div>

      <div class="control-group">
        <p class="control-title">Metric</p>
        <div class="metric-select" id="metricTabs">
          <button type="button" data-metric="word_any_wcs" class="active">Words covered in any context</button>
          <button type="button" data-metric="word_all_wcs">Words covered in all contexts</button>
          <button type="button" data-metric="context_wcs">Context-level coverage</button>
        </div>
      </div>

      <p class="control-title">Line Style</p>
      <div class="style-key">
        <span class="sample-line"></span><span>Base / pre-trained</span>
        <span class="sample-line dashed"></span><span>Instruct / tuned / distilled</span>
      </div>

      <p class="control-title">Model Controls</p>
      <div class="bulk-actions">
        <button type="button" data-action="all">Show all</button>
        <button type="button" data-action="none">Hide all</button>
        <button type="button" data-action="base">Base only</button>
        <button type="button" data-action="instruct">Instruct only</button>
        <button type="button" data-action="pairs">Paired only</button>
        <button type="button" data-action="defaults">Default markers</button>
      </div>
      <div class="model-list" id="modelList"></div>

      <div class="default-list">
        <div><strong>Qwen2.5-14B-Instruct</strong>: top-p 0.8, top-k 20, T 0.7</div>
        <div><strong>Llama-3.1-8B-Instruct</strong>: top-p 0.9, T 0.6</div>
        <div><strong>DeepSeek-R1-Distill-Qwen-14B</strong>: top-p 0.95, T 0.6</div>
        <div><strong>Mistral-7B-Instruct-v0.3</strong>: top-p 0.9, standard vLLM/Transformers-style default when not overridden</div>
      </div>
    </aside>

    <section>
      <div class="chart-head">
        <div>
          <h2 id="chartTitle">top-p Word Coverage</h2>
          <div class="notes" id="chartNotes"></div>
        </div>
        <div class="chart-meta" id="chartMeta"></div>
      </div>
      <div class="chart-wrap">
        <svg id="chart" role="img" aria-label="WCS line chart"></svg>
        <div class="tooltip" id="tooltip"></div>
      </div>
      <div class="loader" id="loader" hidden>
        Could not load <code>useforgraphs.csv</code> automatically. If you opened this page directly from disk, choose the CSV file here.
        <br>
        <input type="file" id="fileInput" accept=".csv,text/csv">
      </div>
    </section>
  </main>

  <script>
    const state = {
      decoder: "top_p",
      metric: "word_any_wcs",
      rows: [],
      models: [],
      enabled: new Set()
    };

    const colors = {
      "Qwen/Qwen2.5-14B": "#2563eb",
      "Qwen/Qwen2.5-14B-Instruct": "#1d4ed8",
      "Qwen/Qwen3.5-9B-Base": "#06b6d4",
      "Qwen/Qwen3.5-9B": "#0891b2",
      "deepseek-ai/DeepSeek-R1-Distill-Qwen-14B": "#dc2626",
      "google/gemma-3-12b-pt": "#16a34a",
      "google/gemma-3-12b-it": "#15803d",
      "google/gemma-4-E4B": "#84cc16",
      "google/gemma-4-E4B-it": "#4d7c0f",
      "meta-llama/Llama-3.1-8B": "#9333ea",
      "meta-llama/Llama-3.1-8B-Instruct": "#7e22ce",
      "mistralai/Mistral-7B-v0.3": "#f97316",
      "mistralai/Mistral-7B-Instruct-v0.3": "#c2410c"
    };

    const displayNames = {
      "Qwen/Qwen2.5-14B": "Qwen2.5-14B",
      "Qwen/Qwen2.5-14B-Instruct": "Qwen2.5-14B-Instruct",
      "Qwen/Qwen3.5-9B-Base": "Qwen3.5-9B-Base",
      "Qwen/Qwen3.5-9B": "Qwen3.5-9B",
      "deepseek-ai/DeepSeek-R1-Distill-Qwen-14B": "DeepSeek-R1-Distill-Qwen-14B",
      "google/gemma-3-12b-pt": "Gemma-3-12B-pt",
      "google/gemma-3-12b-it": "Gemma-3-12B-it",
      "google/gemma-4-E4B": "Gemma-4-E4B",
      "google/gemma-4-E4B-it": "Gemma-4-E4B-it",
      "meta-llama/Llama-3.1-8B": "Llama-3.1-8B",
      "meta-llama/Llama-3.1-8B-Instruct": "Llama-3.1-8B-Instruct",
      "mistralai/Mistral-7B-v0.3": "Mistral-7B-v0.3",
      "mistralai/Mistral-7B-Instruct-v0.3": "Mistral-7B-Instruct-v0.3"
    };

    const modelMeta = {
      "Qwen/Qwen2.5-14B": { pair: "Qwen2.5-14B", variant: "base" },
      "Qwen/Qwen2.5-14B-Instruct": { pair: "Qwen2.5-14B", variant: "instruct" },
      "Qwen/Qwen3.5-9B-Base": { pair: "Qwen3.5-9B", variant: "base" },
      "Qwen/Qwen3.5-9B": { pair: "Qwen3.5-9B", variant: "instruct" },
      "google/gemma-3-12b-pt": { pair: "Gemma-3-12B", variant: "base" },
      "google/gemma-3-12b-it": { pair: "Gemma-3-12B", variant: "instruct" },
      "google/gemma-4-E4B": { pair: "Gemma-4-E4B", variant: "base" },
      "google/gemma-4-E4B-it": { pair: "Gemma-4-E4B", variant: "instruct" },
      "meta-llama/Llama-3.1-8B": { pair: "Llama-3.1-8B", variant: "base" },
      "meta-llama/Llama-3.1-8B-Instruct": { pair: "Llama-3.1-8B", variant: "instruct" },
      "mistralai/Mistral-7B-v0.3": { pair: "Mistral-7B-v0.3", variant: "base" },
      "mistralai/Mistral-7B-Instruct-v0.3": { pair: "Mistral-7B-v0.3", variant: "instruct" },
      "deepseek-ai/DeepSeek-R1-Distill-Qwen-14B": { pair: "DeepSeek-R1-Distill-Qwen-14B", variant: "instruct" }
    };

    const defaultMarkers = [
      {
        model: "Qwen/Qwen2.5-14B-Instruct",
        decoder: "top_p",
        parameter: 0.8,
        label: "Qwen2.5-14B-Instruct default: top-p 0.8, T 0.7"
      },
      {
        model: "Qwen/Qwen2.5-14B-Instruct",
        decoder: "top_k",
        parameter: 20,
        label: "Qwen2.5-14B-Instruct default: top-k 20, T 0.7"
      },
      {
        model: "meta-llama/Llama-3.1-8B-Instruct",
        decoder: "top_p",
        parameter: 0.9,
        label: "Llama-3.1-8B-Instruct default: top-p 0.9, T 0.6"
      },
      {
        model: "deepseek-ai/DeepSeek-R1-Distill-Qwen-14B",
        decoder: "top_p",
        parameter: 0.95,
        label: "DeepSeek official recommendation: top-p 0.95, T 0.6"
      },
      {
        model: "mistralai/Mistral-7B-Instruct-v0.3",
        decoder: "top_p",
        parameter: 0.9,
        label: "Mistral Instruct common default: top-p around 0.9"
      }
    ];

    const metricLabels = {
      word_any_wcs: "Words covered in at least one context",
      word_all_wcs: "Words covered in all contexts",
      context_wcs: "Target-word context coverage"
    };

    const decoderLabels = {
      top_p: "top-p",
      top_k: "top-k",
      min_p: "min-p"
    };

    function parseCsv(text) {
      const lines = text.trim().split(/\r?\n/);
      const headers = splitCsvLine(lines.shift());
      return lines.filter(Boolean).map(line => {
        const values = splitCsvLine(line);
        const row = {};
        headers.forEach((header, index) => row[header] = values[index] ?? "");
        row.parameter = Number(row.parameter);
        row.word_any_wcs = Number(row.word_any_wcs);
        row.word_all_wcs = Number(row.word_all_wcs);
        row.covered_words_any = Number(row.covered_words_any);
        row.covered_words_all = Number(row.covered_words_all);
        row.total_words = Number(row.total_words);
        row.covered_contexts = Number(row.covered_contexts);
        row.total_contexts = Number(row.total_contexts);
        row.context_wcs = row.total_contexts ? row.covered_contexts / row.total_contexts : 0;
        return row;
      });
    }

    function splitCsvLine(line) {
      const out = [];
      let current = "";
      let quoted = false;
      for (let i = 0; i < line.length; i += 1) {
        const char = line[i];
        if (char === '"' && line[i + 1] === '"') {
          current += '"';
          i += 1;
        } else if (char === '"') {
          quoted = !quoted;
        } else if (char === "," && !quoted) {
          out.push(current);
          current = "";
        } else {
          current += char;
        }
      }
      out.push(current);
      return out;
    }

    async function loadData() {
      try {
        const response = await fetch("useforgraphs.csv", { cache: "no-store" });
        if (!response.ok) throw new Error("CSV fetch failed");
        initialize(parseCsv(await response.text()));
      } catch (error) {
        document.getElementById("loader").hidden = false;
      }
    }

    function initialize(rows) {
      state.rows = rows;
      state.models = Array.from(new Set(rows.map(row => row.model))).sort((a, b) => {
        return (displayNames[a] || a).localeCompare(displayNames[b] || b);
      });
      state.enabled = new Set(state.models);
      buildModelControls();
      render();
    }

    function buildModelControls() {
      const list = document.getElementById("modelList");
      list.innerHTML = "";
      groupedPairs().forEach(pair => {
        const row = document.createElement("div");
        row.className = "pair-row";
        const head = document.createElement("div");
        head.className = "pair-head";
        const title = document.createElement("div");
        title.className = "pair-title";
        title.textContent = pair.name;
        const actions = document.createElement("div");
        actions.className = "pair-actions";
        const show = document.createElement("button");
        show.type = "button";
        show.textContent = "Show";
        show.addEventListener("click", () => setModels(pair.models, true));
        const hide = document.createElement("button");
        hide.type = "button";
        hide.textContent = "Hide";
        hide.addEventListener("click", () => setModels(pair.models, false));
        actions.append(show, hide);
        head.append(title, actions);
        const pairModels = document.createElement("div");
        pairModels.className = "pair-models";
        pair.models.forEach(model => {
          pairModels.append(modelToggle(model));
        });
        row.append(head, pairModels);
        list.append(row);
      });
    }

    function groupedPairs() {
      const groups = new Map();
      state.models.forEach(model => {
        const meta = modelMeta[model] || { pair: displayNames[model] || model, variant: "base" };
        if (!groups.has(meta.pair)) groups.set(meta.pair, []);
        groups.get(meta.pair).push(model);
      });
      return Array.from(groups.entries()).map(([name, models]) => ({
        name,
        models: models.sort((a, b) => variantOrder(a) - variantOrder(b) || (displayNames[a] || a).localeCompare(displayNames[b] || b))
      })).sort((a, b) => a.name.localeCompare(b.name));
    }

    function modelToggle(model) {
      const label = document.createElement("label");
      label.className = "model-toggle";
      const input = document.createElement("input");
      input.type = "checkbox";
      input.checked = state.enabled.has(model);
      input.dataset.model = model;
      input.addEventListener("change", () => {
        if (input.checked) state.enabled.add(model);
        else state.enabled.delete(model);
        render();
      });
      const span = document.createElement("span");
      span.innerHTML = `<span class="swatch" style="background:${colors[model] || "#64748b"}"></span>${displayNames[model] || model}`;
      const pill = document.createElement("span");
      const variant = modelMeta[model]?.variant || "base";
      pill.className = `variant-pill ${variant === "base" ? "" : "instruct"}`;
      pill.textContent = variant;
      label.append(input, span, pill);
      return label;
    }

    function variantOrder(model) {
      return (modelMeta[model]?.variant || "base") === "base" ? 0 : 1;
    }

    function setModels(models, enabled) {
      models.forEach(model => {
        if (enabled) state.enabled.add(model);
        else state.enabled.delete(model);
      });
      syncChecks();
      render();
    }

    function syncChecks() {
      document.querySelectorAll("input[data-model]").forEach(input => {
        input.checked = state.enabled.has(input.dataset.model);
      });
    }

    document.getElementById("decoderTabs").addEventListener("click", event => {
      const button = event.target.closest("button[data-decoder]");
      if (!button) return;
      state.decoder = button.dataset.decoder;
      document.querySelectorAll("#decoderTabs button").forEach(item => item.classList.toggle("active", item === button));
      render();
    });

    document.getElementById("metricTabs").addEventListener("click", event => {
      const button = event.target.closest("button[data-metric]");
      if (!button) return;
      state.metric = button.dataset.metric;
      document.querySelectorAll("#metricTabs button").forEach(item => item.classList.toggle("active", item === button));
      render();
    });

    document.querySelector(".bulk-actions").addEventListener("click", event => {
      const button = event.target.closest("button[data-action]");
      if (!button) return;
      const action = button.dataset.action;
      if (action === "all") state.enabled = new Set(state.models);
      if (action === "none") state.enabled = new Set();
      if (action === "base") {
        state.enabled = new Set(state.models.filter(model => (modelMeta[model]?.variant || "base") === "base"));
      }
      if (action === "instruct") {
        state.enabled = new Set(state.models.filter(model => (modelMeta[model]?.variant || "base") !== "base"));
      }
      if (action === "pairs") {
        const paired = groupedPairs()
          .filter(pair => pair.models.length > 1)
          .flatMap(pair => pair.models);
        state.enabled = new Set(paired);
      }
      if (action === "defaults") {
        state.enabled = new Set(defaultMarkers.map(marker => marker.model).filter(model => state.models.includes(model)));
      }
      syncChecks();
      render();
    });

    document.getElementById("fileInput").addEventListener("change", event => {
      const file = event.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = () => {
        document.getElementById("loader").hidden = true;
        initialize(parseCsv(String(reader.result)));
      };
      reader.readAsText(file);
    });

    function render() {
      if (!state.rows.length) return;
      const svg = document.getElementById("chart");
      svg.innerHTML = "";
      const width = svg.clientWidth || 900;
      const height = svg.clientHeight || 560;
      const margin = { top: 34, right: 34, bottom: 58, left: 62 };
      const innerWidth = width - margin.left - margin.right;
      const innerHeight = height - margin.top - margin.bottom;
      svg.setAttribute("viewBox", `0 0 ${width} ${height}`);

      const rows = state.rows.filter(row => row.decoder === state.decoder && state.enabled.has(row.model));
      const byModel = new Map();
      rows.forEach(row => {
        if (!byModel.has(row.model)) byModel.set(row.model, []);
        byModel.get(row.model).push(row);
      });
      byModel.forEach(values => values.sort((a, b) => a.parameter - b.parameter));

      const xValues = rows.map(row => row.parameter);
      const xMin = Math.min(...xValues);
      const xMax = Math.max(...xValues);
      const yMin = 0;
      const yMax = 1;
      const x = value => margin.left + ((value - xMin) / (xMax - xMin || 1)) * innerWidth;
      const y = value => margin.top + (1 - (value - yMin) / (yMax - yMin)) * innerHeight;

      drawGrid(svg, width, height, margin, innerWidth, innerHeight, x, y, xMin, xMax);
      drawDefaults(svg, byModel, x, y, rows);
      drawSeries(svg, byModel, x, y);

      document.getElementById("chartTitle").textContent = `${decoderLabels[state.decoder]} ${metricLabels[state.metric]}`;
      document.getElementById("chartMeta").textContent = `${byModel.size} visible models`;
      document.getElementById("chartNotes").innerHTML = notesForCurrentChart();
    }

    function drawGrid(svg, width, height, margin, innerWidth, innerHeight, x, y, xMin, xMax) {
      const xTicks = ticksForDecoder(state.decoder, xMin, xMax);
      const yTicks = [0, 0.25, 0.5, 0.75, 1];

      yTicks.forEach(tick => {
        line(svg, margin.left, y(tick), width - margin.right, y(tick), "grid");
        text(svg, margin.left - 10, y(tick) + 4, `${Math.round(tick * 100)}%`, "grid-label", "end");
      });
      xTicks.forEach(tick => {
        line(svg, x(tick), margin.top, x(tick), height - margin.bottom, "grid");
        text(svg, x(tick), height - margin.bottom + 24, formatParameter(tick), "grid-label", "middle");
      });
      line(svg, margin.left, height - margin.bottom, width - margin.right, height - margin.bottom, "axis-line");
      line(svg, margin.left, margin.top, margin.left, height - margin.bottom, "axis-line");
      text(svg, margin.left + innerWidth / 2, height - 14, decoderLabels[state.decoder], "grid-label", "middle");
      const yLabel = text(svg, 18, margin.top + innerHeight / 2, metricLabels[state.metric], "grid-label", "middle");
      yLabel.setAttribute("transform", `rotate(-90 18 ${margin.top + innerHeight / 2})`);
    }

    function ticksForDecoder(decoder, min, max) {
      if (decoder === "top_k") return [1, 5, 10, 15, 20].filter(value => value >= min && value <= max);
      if (decoder === "top_p") return [0.5, 0.6, 0.7, 0.8, 0.9, 0.95, 0.99].filter(value => value >= min && value <= max);
      return [0.01, 0.03, 0.05, 0.07, 0.1].filter(value => value >= min && value <= max);
    }

    function drawSeries(svg, byModel, x, y) {
      byModel.forEach((values, model) => {
        const path = values.map((row, index) => `${index ? "L" : "M"}${x(row.parameter).toFixed(2)},${y(row[state.metric]).toFixed(2)}`).join(" ");
        const pathEl = document.createElementNS("http://www.w3.org/2000/svg", "path");
        pathEl.setAttribute("d", path);
        pathEl.setAttribute("class", `series ${variantClass(model)}`);
        pathEl.setAttribute("stroke", colors[model] || "#64748b");
        svg.append(pathEl);

        values.forEach(row => {
          const circle = document.createElementNS("http://www.w3.org/2000/svg", "circle");
          circle.setAttribute("cx", x(row.parameter));
          circle.setAttribute("cy", y(row[state.metric]));
          circle.setAttribute("r", variantClass(model) === "base" ? 3.7 : 4.6);
          circle.setAttribute("class", "point");
          circle.setAttribute("fill", colors[model] || "#64748b");
          circle.addEventListener("mousemove", event => showTooltip(event, row));
          circle.addEventListener("mouseleave", hideTooltip);
          svg.append(circle);
        });
      });
    }

    function variantClass(model) {
      return (modelMeta[model]?.variant || "base") === "base" ? "base" : "instruct";
    }

    function drawDefaults(svg, byModel, x, y, rows) {
      const markers = defaultMarkers.filter(marker => marker.decoder === state.decoder && state.enabled.has(marker.model));
      const drawnLines = new Set();
      markers.forEach(marker => {
        const values = byModel.get(marker.model);
        if (!values) return;
        const row = values.find(item => Math.abs(item.parameter - marker.parameter) < 1e-9);
        if (!row) return;
        const xPos = x(marker.parameter);
        if (!drawnLines.has(marker.parameter)) {
          line(svg, xPos, 34, xPos, 502, "default-line");
          drawnLines.add(marker.parameter);
        }
        const yPos = y(row[state.metric]);
        const circle = document.createElementNS("http://www.w3.org/2000/svg", "circle");
        circle.setAttribute("cx", xPos);
        circle.setAttribute("cy", yPos);
        circle.setAttribute("r", 6);
        circle.setAttribute("class", "default-point");
        circle.addEventListener("mousemove", event => showTooltip(event, row, marker.label));
        circle.addEventListener("mouseleave", hideTooltip);
        svg.append(circle);
        text(svg, Math.min(xPos + 8, (svg.clientWidth || 900) - 180), yPos - 8, shortDefaultLabel(marker), "default-label", "start");
      });
    }

    function shortDefaultLabel(marker) {
      if (marker.model.includes("Qwen2.5")) return marker.decoder === "top_k" ? "Qwen default k=20" : "Qwen default p=0.8";
      if (marker.model.includes("Llama")) return "Llama default p=0.9";
      if (marker.model.includes("DeepSeek")) return "DeepSeek rec p=0.95";
      if (marker.model.includes("Mistral")) return "Mistral p≈0.9";
      return "default";
    }

    function notesForCurrentChart() {
      const active = defaultMarkers.filter(marker => marker.decoder === state.decoder);
      if (!active.length) return "No default-setting markers are defined for this decoder.";
      return active.map(marker => `<div><span class="swatch" style="background:${colors[marker.model] || "#64748b"}"></span>${marker.label}</div>`).join("");
    }

    function formatParameter(value) {
      if (state.decoder === "top_k") return String(Math.round(value));
      return value.toFixed(value < 0.1 ? 2 : 2).replace(/0$/, "").replace(/0$/, "");
    }

    function showTooltip(event, row, extra) {
      const tooltip = document.getElementById("tooltip");
      const metricValue = row[state.metric];
      tooltip.innerHTML = `
        <strong>${displayNames[row.model] || row.model}</strong>
        ${decoderLabels[row.decoder]}: ${formatParameter(row.parameter)}<br>
        ${metricLabels[state.metric]}: ${(metricValue * 100).toFixed(1)}%<br>
        Words any/all: ${row.covered_words_any}/${row.covered_words_all} of ${row.total_words}<br>
        Contexts: ${row.covered_contexts} of ${row.total_contexts}
        ${extra ? `<br><br>${extra}` : ""}
      `;
      const wrap = document.querySelector(".chart-wrap").getBoundingClientRect();
      tooltip.style.left = `${event.clientX - wrap.left}px`;
      tooltip.style.top = `${event.clientY - wrap.top}px`;
      tooltip.style.display = "block";
    }

    function hideTooltip() {
      document.getElementById("tooltip").style.display = "none";
    }

    function line(svg, x1, y1, x2, y2, className) {
      const item = document.createElementNS("http://www.w3.org/2000/svg", "line");
      item.setAttribute("x1", x1);
      item.setAttribute("y1", y1);
      item.setAttribute("x2", x2);
      item.setAttribute("y2", y2);
      item.setAttribute("class", className);
      svg.append(item);
      return item;
    }

    function text(svg, x, y, value, className, anchor) {
      const item = document.createElementNS("http://www.w3.org/2000/svg", "text");
      item.setAttribute("x", x);
      item.setAttribute("y", y);
      item.setAttribute("class", className);
      item.setAttribute("text-anchor", anchor);
      item.textContent = value;
      svg.append(item);
      return item;
    }

    window.addEventListener("resize", render);
    loadData();
  </script>
</body>
</html>
